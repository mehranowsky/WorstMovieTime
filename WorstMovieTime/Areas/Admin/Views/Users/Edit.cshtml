@model ModelLayer.Models.Users

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Edit";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-pencil-square me-2"></i>Edit User
        </h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a asp-area="Admin" asp-action="Index">Users</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-warning text-dark rounded-top d-flex justify-content-between align-items-center py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-person-gear me-2"></i>Editing: @Model?.Name
                    </h5>
                    <span class="badge bg-dark text-warning rounded-pill px-3 py-2">
                        <i class="bi bi-fingerprint me-1"></i>ID: @Model?.Id
                    </span>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" class="needs-validation" novalidate>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3" role="alert">
                            <i class="bi bi-exclamation-triangle me-2"></i>Please correct the following errors:
                        </div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Name" value="@Model?.Name" class="form-control rounded-3" placeholder="Name" />
                                    <label asp-for="Name">
                                        <i class="bi bi-person me-1"></i>Name
                                    </label>
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="PhoneNumber" value="@Model?.PhoneNumber" class="form-control rounded-3" placeholder="Phone Number" />
                                    <label asp-for="PhoneNumber">
                                        <i class="bi bi-telephone me-1"></i>Phone Number
                                    </label>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Email" value="@Model?.Email" type="email" class="form-control rounded-3" placeholder="Email" />
                                    <label asp-for="Email">
                                        <i class="bi bi-envelope me-1"></i>Email
                                    </label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Password" value="@Model?.Password" type="password" class="form-control rounded-3" placeholder="Password" />
                                    <label asp-for="Password">
                                        <i class="bi bi-lock me-1"></i>Password
                                    </label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="Role" value="@Model?.Role" class="form-select rounded-3">
                                        <option value="User">User</option>
                                        <option value="Admin">Admin</option>
                                    </select>
                                    <label asp-for="Role">
                                        <i class="bi bi-shield me-1"></i>Role
                                    </label>
                                    <span asp-validation-for="Role" class="text-danger small"></span>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="card bg-light border-0 rounded-3">
                                    <div class="card-body">
                                        <h6 class="card-title text-muted mb-3">
                                            <i class="bi bi-toggles me-2"></i>Preferences
                                        </h6>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" asp-for="EmailConfirmation" />
                                                    <label class="form-check-label" asp-for="EmailConfirmation">
                                                        <i class="bi bi-envelope-check me-1"></i>Email Confirmation
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-check form-switch">
                                                    <input class="form-check-input" asp-for="IsVIP" />
                                                    <label class="form-check-label" asp-for="IsVIP">
                                                        <i class="bi bi-star me-1"></i>VIP Member
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a asp-area="Admin" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-3">
                                <i class="bi bi-arrow-left me-1"></i>Back to List
                            </a>
                            <div>
                                <a asp-area="Admin" asp-action="Details" asp-route-id="@Model?.Id" class="btn btn-outline-info rounded-pill px-3 me-2">
                                    <i class="bi bi-eye me-1"></i>View Details
                                </a>
                                <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm">
                                    <i class="bi bi-check-lg me-1"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Enable Bootstrap form validation
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
}