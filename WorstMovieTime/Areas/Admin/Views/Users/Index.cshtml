@model IEnumerable<ModelLayer.Models.Users>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Index";
}

<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-list-ul me-2"></i>Users List
        </h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Users</li>
            </ol>
        </nav>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-primary text-white rounded-top d-flex justify-content-between align-items-center py-3">
            <h5 class="card-title mb-0">
                <i class="bi bi-people-fill me-2"></i>Users Management
            </h5>
            <a asp-area="Admin" asp-controller="Users" asp-action="Create" class="btn btn-light rounded-pill px-3 shadow-sm">
                <i class="bi bi-plus-circle me-1"></i>Create New
            </a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.Name)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.Email)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.EmailConfirmation)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.IsVIP)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.Role)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.CreatedAt)
                            </th>
                            <th class="text-nowrap px-3">
                                @Html.DisplayNameFor(model => model.UpdatedAt)
                            </th>
                            <th class="text-end text-nowrap px-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.Name)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.Email)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.EmailConfirmation)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.IsVIP)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.Role)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.CreatedAt)
                                </td>
                                <td class="px-3">
                                    @Html.DisplayFor(modelItem => item.UpdatedAt)
                                </td>
                                <td class="text-end text-nowrap px-3">
                                    <div class="btn-group btn-group-sm" role="group" aria-label="Action buttons">
                                        <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@item.Id" class="me-1 btn btn-outline-warning rounded-pill">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <a asp-area="Admin" asp-controller="Users" asp-action="Details" asp-route-id="@item.Id" class="me-1 btn btn-outline-info rounded-pill">
                                            <i class="bi bi-eye"></i> Details
                                        </a>
                                        <a asp-area="Admin" asp-controller="Users" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger rounded-pill">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-light rounded-bottom">
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">
                    <i class="bi bi-info-circle me-1"></i>Total Records: @Model.Count()
                </small>
            </div>
        </div>
    </div>
</div>